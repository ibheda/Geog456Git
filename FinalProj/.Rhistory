library(tmap)
tm_shape(world_basemap) +
tm_polygons() +
tm_shape(airforceData) +
tm_polygons()
tm_shape(world_basemap) +
tm_polygons() +
tm_shape(airforceData) +
tm_dots()
View(world_basemap)
View(airforceData)
world_basemap <- ne_countries(continent = "europe", scale = "medium", returnclass = "sf")
tm_shape(world_basemap) +
tm_polygons() +
tm_shape(airforceData) +
tm_dots()
world_basemap %<>% filter(sovereignt != "Russia")
