thor <- read_csv("../Data/THOR_WW2_7_31_2013.csv")
world_basemap <- ne_countries(continent = "europe", scale = "medium", returnclass = "sf")
world_basemap <- world_basemap %>% filter(sovereignt != "Russia")
# View dTypes
thor %>%
# Arrange by the number of NA values in each row (ascending)
arrange(rowSums(is.na(.))) %>%
glimpse()
# Clean THOR Dataset ----
thor[thor == "NULL"] <- NA
# Removing rows where over 70% of values are NA
thor_cleaned <- thor %>%
select(where(~ mean(is.na(.x)) <= 0.70))
# Filter out NA geometrt
thor_cleaned <- thor_cleaned %>% filter(!is.na(thor_cleaned$Lon))
# Only American Missions
thor_cleaned <- thor_cleaned %>% filter(Country_Flying_Mission == "USA")
# Filter out NA geometrt
thor_cleaned <- thor_cleaned %>% filter(!is.na(thor_cleaned$Lat))
# Filter to Only European and Mediterranean Theater
thor_cleaned <- thor_cleaned %>% ilter(str_detect(Theater, "ETO|MTO"))
# Filter to Only European and Mediterranean Theater
thor_cleaned <- thor_cleaned %>% filter(str_detect(Theater, "ETO|MTO"))
# View dTypes
thor_cleaned %>%
# Arrange by the number of NA values in each row (ascending)
arrange(rowSums(is.na(.))) %>%
glimpse()
thor_cleaned %>% count(Target_priority_Explanation)
# Get names ready
thor_ready <- thor_cleaned %>%
# 1. Drop the unwanted columns (using starts_with for the GE columns)
select(
-Country_Flying_Mission,
-TGT_Country_Code,
-Target_ID_Code,
-Source_Lat,
-Source_Lon,
-Sighting_Method_Code,
-starts_with("GE_"),
-KML_Date
) %>%
# 2. Convert character columns that should be numbers into numeric
mutate(
across(c(
Day,
Month,
Lat,
Lon,
Target_Priority,
Attacking_AC,
Altitude,
Altitude_Feet,
Tons_of_HE,
TOTAL_TONS,
Airborne_AC,
Number_of_AC_Dropping_Bombs
), as.numeric)
) %>%
# 3. Rename everything to be <= 10 characters, lowercase, and GeoJSON/SHP friendly
rename(
msn_idx    = Master_Index_Number,
theater    = Theater,
msn_date   = MsnDate,
day        = Day,
month      = Month,
year       = Year,
naf        = NAF,
tgt_ctry   = Country_Name,
tgt_loc    = Location_Name,
tgt_type   = Target_Type_Description,
ind_code   = TGT_Industry_Code,
ind_desc   = Target_Industry_Description,
lat        = Lat,
lon        = Lon,
mds        = MDS,
ac_name    = Aircraft_name,
tgt_pri    = Target_Priority,
pri_desc   = Target_priority_Explanation,
atk_ac     = Attacking_AC,
alt        = Altitude,
alt_ft     = Altitude_Feet,
he_tons    = Tons_of_HE,
tot_tons   = TOTAL_TONS,
air_ac     = Airborne_AC,
drop_ac    = Number_of_AC_Dropping_Bombs
)
# Convert to SF ----
thor_GEO <- st_as_sf(thor, coords = c("Lon", "Lat"),
crs = 4326)
# Convert to SF ----
thor_GEO <- st_as_sf(thor_ready, coords = c("lon", "lat"),
crs = 4326)
tm_shape(world_basemap) +
tm_polygons() +
tm_shape(thor_GEO) +
tm_dots()
thor_GEOeuro <- st_intersection(thor_GEO, st_geometry(world_basemap))
tm_shape(world_basemap) +
tm_polygons() +
tm_shape(thor_GEOero) +
tm_dots()
tm_shape(world_basemap) +
tm_polygons() +
tm_shape(thor_GEOeuro) +
tm_dots()
write_sf(thor_GEOeuro, "../Data/THORSHP/thorEuro.shp")
write_sf(thor_GEOeuro, "../Data/THORSHP/thorEuro.geojson")
# 1. Load the datasets
thor <- st_read("../Data/THORSHP/thorEuro.geojson")
ep2 <- st_read("../Data/thorEuro.geojson")
ep2 <- st_read("../Data/europePoints2.geojson")
# 2. Clean and parse dates
# THOR has separate year, month, day columns
thor_clean <- thor %>%
mutate(
year = as.numeric(year),
month = as.numeric(month),
day = as.numeric(day),
date = make_date(year, month, day)
) %>%
filter(!is.na(date))
# EuropePoints2 has a standard date string
ep2_clean <- ep2 %>%
mutate(date = ymd(date)) %>%
filter(!is.na(date))
thor_proj <- st_transform(thor_clean, 3857)
ep2_proj <- st_transform(ep2_clean, 3857)
# 4. Perform an Inner Join on the exact date
# We convert to data frames to join on attributes without sf complaining about multiple geometry columns
joined_df <- inner_join(
as.data.frame(thor_proj),
as.data.frame(ep2_proj),
by = "date",
suffix = c("_thor", "_ep2"),
relationship = "many-to-many"
)
# 5. Calculate element-wise spatial distance and filter
matches <- joined_df %>%
mutate(
# Calculate distance between the two geometry columns
dist_m = as.numeric(st_distance(geometry_thor, geometry_ep2, by_element = TRUE)),
distance_km = dist_m / 1000
) %>%
filter(distance_km < 50) %>%
arrange(distance_km)
# View the top matches
head(matches %>% select(date, distance_km, tgt_loc, location_name, text))
View(matches)
