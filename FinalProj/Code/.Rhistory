thor_cleaned <- filter(!is.na(thor_cleaned$Lat))
class(thor_cleaned)
thor_cleaned <- filter(!is.na(thor_cleaned$Lat))
thor_cleaned <- thor_cleaned %>% filter(Country_Flying_Mission == "USA")
thor_cleaned <- thor_cleaned %>% filter(!is.na(thor$Lat))
thor_cleaned <- thor_cleaned %>% filter(!is.na(thor_cleaned$Lat))
thor_cleaned <- thor_cleaned %>% filter(!is.na(thor_cleaned$Lon))
