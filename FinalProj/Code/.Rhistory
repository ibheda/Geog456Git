library(sf)
library(dplyr)
# Load the points
points <- st_read("../Data/europePoints2.geojson")
# Group by theatre, sort by date, and cast to lines
theatre_lines <- points %>%
group_by(theatre) %>%
arrange(date) %>%
summarize(do_union = FALSE) %>% # Keep points in chronological order
st_cast("LINESTRING")
st_write(theatre_lines, "../Data/theatrePaths.geojson")
